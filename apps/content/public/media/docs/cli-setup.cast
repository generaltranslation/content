[15.239184, "o", "\u001b[999D\u001b[4A\u001b[1B\u001b[J\u001b[32m◇\u001b[39m  Which languages would you like to translate your project into?\r\r\n\u001b[90m│\u001b[39m  \u001b[2mes fr\u001b[22m"]
[15.239217, "o", "\r\r\n"]
[15.239265, "o", "\u001b[?25h"]
[15.240025, "o", "\u001b[?25l\u001b[90m│\u001b[39m\r\r\n\u001b[36m◆\u001b[39m  What is the format of your language resource files? Select as many as applicable.\r\r\nAdditionally, you can translate any other files you have in your project.\r\r\n\u001b[36m│\u001b[39m  \u001b[36m◻\u001b[39m JSON\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mMarkdown\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mMDX\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mTypeScript\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mJavaScript\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mYAML\u001b[22m\r\r\n\u001b[36m└\u001b[39m\r\r\n"]
[19.254585, "o", "\u001b[999D\u001b[10A\u001b[3B\u001b[2K\u001b[G\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m JSON\u001b[7B\u001b[999D\u001b[10A\u001b[3B\u001b[J\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m \u001b[2mJSON\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[36m◻\u001b[39m Markdown\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mMDX\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mTypeScript\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mJavaScript\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[2m◻\u001b[22m \u001b[2mYAML\u001b[22m\r\r\n\u001b[36m└\u001b[39m\r\r\n\u001b[999D\u001b[10A\u001b[4B\u001b[2K\u001b[G\u001b[36m│\u001b[39m  \u001b[32m◼\u001b[39m Markdown\u001b[6B"]
[19.255223, "o", "\u001b[999D\u001b[10A\u001b[1B"]
[19.255357, "o", "\u001b[J\u001b[32m◇\u001b[39m  What is the format of your language resource files? Select as many as applicable.\r\r\nAdditionally, you can translate any other files you have in your project.\r\r\n\u001b[90m│\u001b[39m  \u001b[2mJSON\u001b[22m\u001b[2m, \u001b[22m\u001b[2mMarkdown\u001b[22m\r\r\n"]
