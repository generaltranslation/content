[15.238499, "o", "\u001b[999D\u001b[4A\u001b[1B\u001b[J\u001b[32m◇\u001b[39m  What is the default locale for your project?\r\r\n\u001b[90m│\u001b[39m  \u001b[2men-US\u001b[22m\r\r\n"]
[15.238561, "o", "\u001b[?25h"]
