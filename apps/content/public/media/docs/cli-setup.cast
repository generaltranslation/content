[15.234518, "o", "\u001b[36m\u001b[39m\r\r\n\u001b[36m    @@@@@@@@@@@@@@@@@@@@@@\u001b[39m\r\r\n\u001b[36m  @@  @@@@@@@@@@@@ @@@@@@@\u001b[39m\r\r\n\u001b[36m @@ @@@          @ @\u001b[39m\r\r\n\u001b[36m@@ @@            @ @\u001b[39m\r\r\n\u001b[36m@@ @      @@@@@  @ @\u001b[39m\r\r\n\u001b[36m@@ @@     @@@ @  @ @\u001b[39m\r\r\n\u001b[36m @@ @@      @ @  @ @\u001b[39m\r\r\n\u001b[36m  @@  @@@@@@@ @  @ @\u001b[39m\r\r\n\u001b[36m    @@@@@@@@@    @ @\u001b[39m\r\r\n"]
[15.234578, "o", "\r\r\n\u001b[1m\u001b[34mGeneral Translation, Inc.\u001b[39m\u001b[22m\r\r\n\u001b[2mhttps://generaltranslation.com/docs\u001b[22m\r\r\n\u001b[2mCLI Version: 2.14.64\u001b[22m\r\r\n\u001b[2m\u001b[22m\r\r\n"]
[15.234604, "o", "\u001b[90m┌\u001b[39m  \u001b[36mRunning setup wizard...\u001b[39m\r\r\n"]
[15.236474, "o", "\u001b[?25l\u001b[90m│\u001b[39m\r\r\n\u001b[36m◆\u001b[39m  Would you like to use the recommended General Translation defaults? \u001b[2m(Files saved locally in \u001b[22m\r\r\n\u001b[2m./public/_gt)\u001b[22m\r\r\n\u001b[36m│\u001b[39m  \u001b[32m●\u001b[39m Yes \u001b[2m/\u001b[22m \u001b[2m○\u001b[22m \u001b[2mNo\u001b[22m\r\r\n\u001b[36m└\u001b[39m\r\r\n"]
[15.237086, "o", "\u001b[999D\u001b[5A\u001b[3B"]
[15.237163, "o", "\u001b[2K\u001b[G\u001b[36m│\u001b[39m  \u001b[2m○\u001b[22m \u001b[2mYes\u001b[22m \u001b[2m/\u001b[22m \u001b[32m●\u001b[39m No\u001b[2B"]
[15.23734, "o", "\u001b[999D\u001b[5A\u001b[1B\u001b[J\u001b[32m◇\u001b[39m  Would you like to use the recommended General Translation defaults? \u001b[2m(Files saved locally in \u001b[22m\r\r\n\u001b[2m./public/_gt)\u001b[22m\r\r\n\u001b[90m│\u001b[39m  \u001b[2mNo\u001b[22m"]
[15.237384, "o", "\r\r\n"]
[15.237454, "o", "\u001b[?25h"]
[15.237787, "o", "\u001b[?25l\u001b[90m│\u001b[39m\r\r\n\u001b[36m◆\u001b[39m  What is the default locale for your project?\r\r\n\u001b[36m│\u001b[39m  \u001b[7me\u001b[27m\u001b[2mn\u001b[22m\r\r\n\u001b[36m└\u001b[39m\r\r\n"]
